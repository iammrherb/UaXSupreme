<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dot1Xer Supreme Enterprise Edition</title>
    <link rel="stylesheet" href="css/main.css">
    <link rel="stylesheet" href="css/vendors.css">
    <link rel="stylesheet" href="css/help.css">
    <link rel="stylesheet" href="css/vendor-fix.css">
    <link rel="stylesheet" href="css/help-fix.css">
    
    <!-- External libraries -->
    <script src="lib/jspdf.min.js"></script>
    <script src="lib/html2canvas.min.js"></script>
    <script src="lib/FileSaver.min.js"></script>
    <script src="lib/ai-integration.js"></script>
    
    <!-- Emergency fixes -->
    <script>
    // Prevent duplicate declarations by setting up a module registry
    window.moduleRegistry = {
        vendors: false,
        help: false,
        ui: false,
        configGenerator: false,
        diagrams: false,
        questionnaire: false,
        checklistHandler: false
    };
    
    // Fix showAlert to prevent recursive calls
    window.originalAlert = window.alert;
    window.showAlert = function(message, type) {
        console.log("Alert: " + message);
        var alertDiv = document.createElement("div");
        alertDiv.className = "alert " + (type || "alert-info");
        alertDiv.innerHTML = message;
        alertDiv.style.position = "fixed";
        alertDiv.style.top = "10px";
        alertDiv.style.right = "10px";
        alertDiv.style.zIndex = "9999";
        alertDiv.style.maxWidth = "300px";
        alertDiv.style.padding = "10px 15px";
        alertDiv.style.borderRadius = "4px";
        alertDiv.style.boxShadow = "0 2px 5px rgba(0,0,0,0.2)";
        
        // Style based on type
        if (type === "alert-success") {
            alertDiv.style.backgroundColor = "#d4edda";
            alertDiv.style.color = "#155724";
        } else if (type === "alert-danger") {
            alertDiv.style.backgroundColor = "#f8d7da";
            alertDiv.style.color = "#721c24";
        } else if (type === "alert-warning") {
            alertDiv.style.backgroundColor = "#fff3cd";
            alertDiv.style.color = "#856404";
        } else {
            alertDiv.style.backgroundColor = "#d1ecf1";
            alertDiv.style.color = "#0c5460";
        }
        
        document.body.appendChild(alertDiv);
        
        setTimeout(function() {
            alertDiv.parentNode && alertDiv.parentNode.removeChild(alertDiv);
        }, 3000);
    };
    
    // Function to create placeholder for missing modules
    window.createPlaceholder = function(moduleName, obj) {
        if (!window[moduleName]) {
            window[moduleName] = obj || {};
            console.log("Created placeholder for " + moduleName);
        }
    };
    </script>
</head>
<body>
    <script src="lib/ai-integration.js"></script>
<link rel="stylesheet" href="css/vendor-fix.css">
    <link rel="stylesheet" href="css/help-fix.css">
    
    <!-- Fix for password field warnings - wrap all in forms -->
    <script>
    document.addEventListener("DOMContentLoaded", function() {
        // Fix password fields by wrapping them in forms
        var passwordFields = document.querySelectorAll('input[type="password"]');
        passwordFields.forEach(function(field) {
            // Skip if already in a form
            if (field.closest('form')) return;
            
            // Create a form element
            var form = document.createElement('form');
            form.setAttribute('autocomplete', 'on');
            form.setAttribute('method', 'post');
            form.setAttribute('action', 'javascript:void(0);'); // Non-submitting form
            form.className = 'password-form-wrapper';
            form.style.margin = '0';
            form.style.padding = '0';
            
            // Get the parent node
            var parent = field.parentNode;
            
            // Replace the field with the form containing the field
            parent.insertBefore(form, field);
            form.appendChild(field);
            
            // Add proper autocomplete attribute based on field id
            if (field.id.includes('secret')) {
                field.setAttribute('autocomplete', 'current-password');
            } else if (field.id.includes('api-key')) {
                field.setAttribute('autocomplete', 'off'); // API keys shouldn't be saved
            }
        });
    });
    </script>
    
    <!-- Core scripts - loaded once in the correct order -->
    <script src="js/vendors.js"></script>
    <script src="js/main.js"></script>
    <script src="js/ui.js"></script>
    <script src="js/help.js"></script>
    <script src="js/config-generator.js"></script>
    <script src="js/diagrams.js"></script>
    <script src="js/questionnaire.js"></script>
    <script src="js/checklist-handler.js"></script>
    
    <!-- Placeholder scripts for missing resources -->
    <script>
    // Create placeholders for missing JS files
    if (!window.documentGenerator) {
        window.documentGenerator = {
            generateDocument: function(format) {
                showAlert("Document generation is not available in this version", "alert-warning");
                return false;
            }
        };
    }
    
    if (!window.aiAssistant) {
        window.aiAssistant = {
            initialize: function() {
                console.log("AI Assistant placeholder initialized");
            },
            askQuestion: function(question) {
                showAlert("AI Assistant is not available in this version", "alert-info");
                return "I'm sorry, AI assistance is not available in this version.";
            }
        };
    }
    </script>
    
    <!-- Fix scripts -->
    <script src="js/vendor-fix.js"></script>
    <script src="js/help-fix.js"></script>
    <script src="js/emergency-fix.js"></script>
</body>
</html>
